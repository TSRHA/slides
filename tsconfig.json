{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "preserve"
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.vue",
    "layouts/**/*.vue",
    "data/**/*.ts",
    "*.ts",
    "shims.d.ts"
  ],
  "exclude": ["node_modules", "dist", "export"]
}
